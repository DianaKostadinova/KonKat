spring:
  application:
    name: konkat

  datasource:
    url: jdbc:postgresql://localhost:5432/konkat
    username: postgres
    password: YOUR_POSTGRES_PASSWORD
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        dialect: org.hibernate.dialect.PostgreSQLDialect
        format_sql: true

server:
  port: 8082

app:
  clerk:
    # Find your Frontend API URL at: https://dashboard.clerk.com → API Keys
    # Format: https://<your-app>.clerk.accounts.dev
    jwks-uri: "https://YOUR_CLERK_FRONTEND_API/.well-known/jwks.json"
