spring:
  application:
    name: konkat

  datasource:
    url: jdbc:postgresql://localhost:5432/konkat
    username: postgres
    password: YOUR_POSTGRES_PASSWORD
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        dialect: org.hibernate.dialect.PostgreSQLDialect
        format_sql: true

server:
  port: 8082

app:
  firebase:
    project-id: "YOUR_FIREBASE_PROJECT_ID"
    jwks-uri: "https://www.googleapis.com/service_accounts/v1/jwk/securetoken@system.gserviceaccount.com"
