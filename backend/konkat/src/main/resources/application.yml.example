spring:
  application:
    name: konkat

  datasource:
    url: jdbc:postgresql://localhost:5432/konkat
    username: postgres
    password: YOUR_POSTGRES_PASSWORD
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        dialect: org.hibernate.dialect.PostgreSQLDialect
        format_sql: true

server:
  port: 8080

app:
  jwt:
    secret: "your-long-random-secret-key-here-minimum-32-characters"
    expiration-ms: 86400000
