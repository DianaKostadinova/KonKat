# Copy this file to .env and fill in your values.
# docker compose automatically loads .env from the project root.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Clerk — get your JWKS URI from dashboard.clerk.com → API Keys
# Format: https://<your-app>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URI=https://YOUR_CLERK_FRONTEND_API/.well-known/jwks.json
